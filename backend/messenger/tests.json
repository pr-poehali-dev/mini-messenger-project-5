{
  "tests": [
    {
      "name": "Login by email - not found",
      "method": "POST",
      "path": "/?action=login_email",
      "body": {"email": "zzz_not_exist_999@mail.ru", "password": "anypass", "device_id": "test-device-x"},
      "expectedStatus": 404,
      "expectedBody": {"error": "Аккаунт с такой почтой не найден"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Register - bad email domain",
      "method": "POST",
      "path": "/?action=register",
      "body": {"email": "test@gmail.com", "password": "123456", "first_name": "Иван", "last_name": "Иванов", "city": "Москва", "birthdate": "2000-01-01", "phone": "+79991234567", "consent_152": true, "consent_terms": true, "consent_rules": true},
      "expectedStatus": 400,
      "expectedBody": {"error": "Регистрация доступна только с почтой @mail.ru"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Forgot password - not found",
      "method": "POST",
      "path": "/?action=forgot_password",
      "body": {"email": "zzz_not_exist_999@mail.ru"},
      "expectedStatus": 404,
      "expectedBody": {"error": "Аккаунт с такой почтой не найден"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Search returns list",
      "method": "GET",
      "path": "/?action=search&q=zzzznotexist&user_id=0",
      "expectedStatus": 200,
      "expectedBody": {"users": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Call signal send",
      "method": "POST",
      "path": "/?action=call_signal",
      "body": {"call_id": "test-call-1", "from_user_id": 1, "to_user_id": 2, "type": "offer", "payload": "{}", "kind": "video"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Call status check",
      "method": "GET",
      "path": "/?action=call_status&call_id=nonexistent-call",
      "expectedStatus": 200,
      "expectedBody": {"status": "ended"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Mark read",
      "method": "POST",
      "path": "/?action=mark_read",
      "body": {"chat_id": 1, "user_id": 1},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Profile get - not found",
      "method": "GET",
      "path": "/?action=profile&user_id=999999&me=0",
      "expectedStatus": 404,
      "expectedBody": {"error": "Не найден"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Chat poll - empty",
      "method": "GET",
      "path": "/?action=chat_poll&chat_id=0&after=0&user_id=0&peer_id=0",
      "expectedStatus": 200,
      "expectedBody": {"messages": [], "typing": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Feed - empty for unknown user",
      "method": "GET",
      "path": "/?action=feed&user_id=0",
      "expectedStatus": 200,
      "expectedBody": {"posts": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Statuses feed - empty for unknown user",
      "method": "GET",
      "path": "/?action=statuses_feed&user_id=0",
      "expectedStatus": 200,
      "expectedBody": {"feed": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Statuses user - empty for unknown user",
      "method": "GET",
      "path": "/?action=statuses_user&user_id=0&me=0",
      "expectedStatus": 200,
      "expectedBody": {"statuses": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Status create - bad data",
      "method": "POST",
      "path": "/?action=status_create",
      "body": {"user_id": 0, "type": "text", "content": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "Некорректные данные статуса"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Status delete - not found",
      "method": "POST",
      "path": "/?action=status_delete",
      "body": {"status_id": 999999, "user_id": 0},
      "expectedStatus": 404,
      "expectedBody": {"error": "Статус не найден"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Post search - empty query",
      "method": "GET",
      "path": "/?action=post_search&user_id=0&q=",
      "expectedStatus": 200,
      "expectedBody": {"posts": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Post create - bad data",
      "method": "POST",
      "path": "/?action=post_create",
      "body": {"user_id": 0, "type": "text", "content": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "Некорректные данные публикации"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Post edit - not found",
      "method": "POST",
      "path": "/?action=post_edit",
      "body": {"user_id": 0, "post_id": 999999, "content": "test"},
      "expectedStatus": 404,
      "expectedBody": {"error": "Публикация не найдена"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Post comment add - empty text",
      "method": "POST",
      "path": "/?action=post_comment_add",
      "body": {"user_id": 0, "post_id": 999999, "text": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "Пустой комментарий"},
      "bodyMatcher": "partial"
    }
  ]
}