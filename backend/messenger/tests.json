{
  "tests": [
    {
      "name": "Login by nick - not found",
      "method": "POST",
      "path": "/?action=login_by_nick",
      "body": {"nick": "zzz_not_exist_999", "password": "anypass", "device_id": "test-device-x"},
      "expectedStatus": 404,
      "expectedBody": {"error": "Аккаунт с таким ником не найден"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Search returns list",
      "method": "GET",
      "path": "/?action=search&q=zzzznotexist&user_id=0",
      "expectedStatus": 200,
      "expectedBody": {"users": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Call signal send",
      "method": "POST",
      "path": "/?action=call_signal",
      "body": {"call_id": "test-call-1", "from_user_id": 1, "to_user_id": 2, "type": "offer", "payload": "{}", "kind": "video"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Call status check",
      "method": "GET",
      "path": "/?action=call_status&call_id=nonexistent-call",
      "expectedStatus": 200,
      "expectedBody": {"status": "ended"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Mark read",
      "method": "POST",
      "path": "/?action=mark_read",
      "body": {"chat_id": 1, "user_id": 1},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Profile get - not found",
      "method": "GET",
      "path": "/?action=profile&user_id=999999&me=0",
      "expectedStatus": 404,
      "expectedBody": {"error": "Не найден"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Chat poll - empty",
      "method": "GET",
      "path": "/?action=chat_poll&chat_id=0&after=0&user_id=0&peer_id=0",
      "expectedStatus": 200,
      "expectedBody": {"messages": [], "typing": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Realty list",
      "method": "GET",
      "path": "/?action=realty_list&deal_type=sale",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Statuses feed - empty for unknown user",
      "method": "GET",
      "path": "/?action=statuses_feed&user_id=0",
      "expectedStatus": 200,
      "expectedBody": {"feed": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Statuses user - empty for unknown user",
      "method": "GET",
      "path": "/?action=statuses_user&user_id=0&me=0",
      "expectedStatus": 200,
      "expectedBody": {"statuses": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Status create - bad data",
      "method": "POST",
      "path": "/?action=status_create",
      "body": {"user_id": 0, "type": "text", "content": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "Некорректные данные статуса"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Status delete - not found",
      "method": "POST",
      "path": "/?action=status_delete",
      "body": {"status_id": 999999, "user_id": 0},
      "expectedStatus": 404,
      "expectedBody": {"error": "Статус не найден"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Realty pay create - listing not found",
      "method": "POST",
      "path": "/?action=realty_pay_create",
      "body": {"listing_id": 999999, "user_id": 0},
      "expectedStatus": 404,
      "expectedBody": {"error": "Объявление не найдено"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Realty pay status - listing not found",
      "method": "GET",
      "path": "/?action=realty_pay_status&listing_id=999999&user_id=0",
      "expectedStatus": 404,
      "expectedBody": {"error": "Не найдено"},
      "bodyMatcher": "partial"
    }
  ]
}