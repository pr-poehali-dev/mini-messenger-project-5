{
  "tests": [
    {
      "name": "Login by existing device",
      "method": "POST",
      "path": "/?action=login",
      "body": {"nick": "__device_auto__", "device_id": "test-device-99b"},
      "expectedStatus": 200,
      "expectedBody": {"user": {"nick": "tester99"}},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login by nick - not found",
      "method": "POST",
      "path": "/?action=login_by_nick",
      "body": {"nick": "zzz_not_exist_999", "device_id": "test-device-x"},
      "expectedStatus": 404,
      "expectedBody": {"error": "Аккаунт с таким ником не найден"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login by nick - success",
      "method": "POST",
      "path": "/?action=login_by_nick",
      "body": {"nick": "tester99", "device_id": "test-device-99b"},
      "expectedStatus": 200,
      "expectedBody": {"user": {"nick": "tester99"}},
      "bodyMatcher": "partial"
    },
    {
      "name": "Search returns list",
      "method": "GET",
      "path": "/?action=search&q=zzzznotexist&user_id=0",
      "expectedStatus": 200,
      "expectedBody": {"users": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Mark read",
      "method": "POST",
      "path": "/?action=mark_read",
      "body": {"chat_id": 1, "user_id": 1},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Profile get",
      "method": "GET",
      "path": "/?action=profile&user_id=1&me=0",
      "expectedStatus": 200,
      "expectedBody": {"user": {}},
      "bodyMatcher": "partial"
    }
  ]
}