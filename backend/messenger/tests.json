{
  "tests": [
    {
      "name": "Login creates user",
      "method": "POST",
      "path": "/?action=login",
      "body": {"nick": "tester99", "device_id": "test-device-99"},
      "expectedStatus": 200,
      "expectedBody": {"user": {"nick": "tester99"}},
      "bodyMatcher": "partial"
    },
    {
      "name": "Search returns list",
      "method": "GET",
      "path": "/?action=search&q=zzzznotexist&user_id=0",
      "expectedStatus": 200,
      "expectedBody": {"users": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Profile get",
      "method": "GET",
      "path": "/?action=profile&user_id=1&me=0",
      "expectedStatus": 200,
      "expectedBody": {"user": {}},
      "bodyMatcher": "partial"
    }
  ]
}